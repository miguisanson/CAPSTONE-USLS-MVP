NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:password@localhost:3306/usls_gs_mvp"
JWT_SECRET="replace_with_at_least_32_characters_secret"
JWT_EXPIRES_IN=8h
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
PORTAL_BASE_URL=http://localhost:5173
UPLOAD_DIR=uploads
# Force native Prisma engine for Node backend runtime.
PRISMA_CLIENT_ENGINE_TYPE=binary

# SMTP (safe email notifications with portal link only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM=no-reply@graduateschool.local
SMTP_SECURE=false

# Monitoring
MONITOR_CRON=*/30 * * * *

# Optional AI assistance for prescriptive analytics (off by default)
ENABLE_OPENAI_ASSIST=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
